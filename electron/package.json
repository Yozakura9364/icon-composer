{
  "name": "icon-composer",
  "version": "1.0.0",
  "description": "FFXIV 图层合成工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable --x64",
    "build-dir": "electron-builder --win dir --x64"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.ffxiv.icon-composer",
    "productName": "Icon Composer",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "IconComposer-${version}-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "../../server.js",
      "../../index.html",
      "../../public/**/*",
      "../../id-names.json"
    ],
    "extraResources": [],
    "asar": true
  }
}
